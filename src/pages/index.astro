---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Card from "../components/Card.astro";
import Timeline from "../components/Timeline.astro";
import Gallery from "../components/Gallery.astro";
import Footer from "../components/Footer.astro";
import { divisions } from "../data/content";
---

<Layout title="Home">
  <Navbar />
  <main>
    <Hero />

    <!-- History -->
    <section class="camo-bg">
      <div class="text-center mb-20">
        <div class="reveal">
          <span
            data-i18n="home.history.label"
            class="text-accent text-[10px] font-bold uppercase tracking-[0.5em] mb-4 block"
            >History</span
          >
        </div>
        <div class="reveal delay-100">
          <h2
            data-i18n-html="home.history.title"
            class="text-4xl sm:text-5xl md:text-6xl mb-4 sm:mb-6"
          >
            The Journey of <span class="text-primary">[Unit Name]</span>
          </h2>
        </div>
        <div class="reveal delay-200">
          <p
            data-i18n="home.history.desc"
            class="max-w-2xl mx-auto opacity-60 text-sm"
          >
            Since its founding, this unit has carried out numerous operations
            and missions that shaped its identity as a strategic force.
          </p>
        </div>
      </div>

      <Timeline />

      <div class="text-center mt-16 reveal">
        <a
          href="/sejarah"
          class="btn-tactical py-4 px-12"
          data-i18n="home.history.cta">Read More</a
        >
      </div>
    </section>

    <!-- Divisions -->
    <section class="bg-base-200 py-20 sm:py-32">
      <div
        class="flex flex-col md:flex-row items-start md:items-end justify-between mb-12 sm:mb-20 gap-6 sm:gap-8"
      >
        <div class="max-w-xl">
          <div class="reveal">
            <span
              data-i18n="home.org.label"
              class="text-accent text-[10px] font-bold uppercase tracking-[0.5em] mb-4 block"
              >Organization</span
            >
          </div>
          <div class="reveal delay-100">
            <h2
              data-i18n-html="home.org.title"
              class="text-4xl sm:text-5xl md:text-6xl mb-4 sm:mb-6"
            >
              <span class="text-primary">[Type]</span> Divisions
            </h2>
          </div>
          <div class="reveal delay-200">
            <p data-i18n="home.org.desc" class="opacity-60 text-sm">
              [Unit Name] oversees three divisions spread across multiple
              regions.
            </p>
          </div>
        </div>
        <div class="reveal">
          <a
            href="/struktur"
            class="text-[10px] uppercase font-bold tracking-widest border-b-2 border-primary pb-2 hover:text-accent transition-colors"
            data-i18n="home.org.link">View All →</a
          >
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-primary/10">
        {
          divisions.map((div, i) => (
            <div class={`reveal delay-${(i + 1) * 100}`}>
              <Card
                title={div.title}
                location={div.location}
                description={div.description}
                iconType={div.iconType}
                descKey={div.descKey}
              />
            </div>
          ))
        }
      </div>
    </section>

    <!-- Gallery -->
    <section class="py-20 sm:py-32">
      <div class="text-center mb-20">
        <div class="reveal">
          <span
            data-i18n="home.gallery.label"
            class="text-accent text-[10px] font-bold uppercase tracking-[0.5em] mb-4 block"
            >Documentation</span
          >
        </div>
        <div class="reveal delay-100">
          <h2
            data-i18n-html="home.gallery.title"
            class="text-4xl sm:text-5xl md:text-6xl mb-4 sm:mb-6"
          >
            Photo <span class="text-primary">Gallery</span>
          </h2>
        </div>
      </div>

      <div class="reveal-scale">
        <Gallery />
      </div>

      <div class="text-center mt-16 reveal">
        <a
          href="/galeri"
          class="text-[10px] uppercase font-bold tracking-[0.4em] hover:text-accent transition-colors"
          data-i18n="home.gallery.link">View All Photos →</a
        >
      </div>
    </section>
  </main>
  <Footer />
</Layout>
