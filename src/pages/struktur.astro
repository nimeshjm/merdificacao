---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Card from "../components/Card.astro";
import { divisions, commanderInfo } from "../data/content";
---

<Layout
  title="Structure"
  description="The organizational structure and divisions of [Unit Name]."
>
  <Navbar />
  <main>
    <section class="pt-24 sm:pt-32 pb-16 sm:pb-20 border-b border-primary/10">
      <div class="max-w-4xl mx-auto text-center">
        <div class="reveal">
          <span
            data-i18n="struktur.label"
            class="text-accent text-[10px] font-bold uppercase tracking-[0.5em] mb-4 block"
            >Organization</span
          >
        </div>
        <div class="reveal delay-100">
          <h1
            data-i18n-html="struktur.title"
            class="text-4xl sm:text-5xl md:text-7xl mb-6 sm:mb-8"
          >
            Command <span class="text-primary">Structure</span>
          </h1>
        </div>
        <div class="reveal delay-200">
          <p
            data-i18n="struktur.desc"
            class="text-base sm:text-lg opacity-70 leading-relaxed max-w-2xl mx-auto"
          >
            [Unit Name] is led by a Commander, reporting directly to [Superior].
          </p>
        </div>
      </div>
    </section>

    <section>
      <div class="mb-20 reveal">
        <h2 data-i18n-html="struktur.div.title" class="text-4xl mb-6">
          <span class="text-accent">[Type]</span> Divisions
        </h2>
        <p data-i18n="struktur.div.desc" class="max-w-xl opacity-60 text-sm">
          [Unit Name] oversees three divisions, each headquartered in different
          regions.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          divisions.map((div, i) => (
            <div class={`reveal delay-${(i + 1) * 100}`}>
              <Card
                title={div.title}
                location={div.location}
                description={div.description}
                iconType={div.iconType}
                descKey={div.descKeyStruktur}
              />
            </div>
          ))
        }
      </div>

      <div
        class="mt-20 sm:mt-32 p-6 sm:p-12 bg-secondary text-primary-content border border-primary/20 reveal"
      >
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-20">
          <div>
            <h3
              data-i18n={commanderInfo.titleI18nKey}
              class="text-3xl mb-6 text-accent"
            >
              {commanderInfo.title}
            </h3>
            <p
              data-i18n={commanderInfo.descI18nKey}
              class="opacity-70 text-sm leading-relaxed mb-8"
            >
              {commanderInfo.description}
            </p>
            <ul
              class="text-[10px] font-bold uppercase tracking-[0.2em] space-y-4 opacity-50"
            >
              {
                commanderInfo.subunits.map((unit) => (
                  <li data-i18n={unit.i18nKey}>{unit.text}</li>
                ))
              }
            </ul>
          </div>
          <div
            class="hidden md:flex items-center justify-center border-l border-primary/10 pl-20"
          >
            <div class="text-center">
              <div class="w-32 h-1 bg-accent mb-4 mx-auto"></div>
              <span
                data-i18n={commanderInfo.badgeI18nKey}
                class="text-xs tracking-[0.5em] font-bold uppercase"
                >{commanderInfo.badgeText}</span
              >
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
