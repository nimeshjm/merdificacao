---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Gallery from "../components/Gallery.astro";
---

<Layout
  title="Gallery"
  description="Photo documentation of operational activities, training exercises, and peacekeeping missions."
>
  <Navbar />
  <main>
    <section class="pt-24 sm:pt-32 pb-16 sm:pb-20 bg-base-200">
      <div class="max-w-4xl mx-auto text-center">
        <div class="reveal">
          <span
            data-i18n="galeri.label"
            class="text-accent text-[10px] font-bold uppercase tracking-[0.5em] mb-4 block"
            >Documentation</span
          >
        </div>
        <div class="reveal delay-100">
          <h1
            data-i18n-html="galeri.title"
            class="text-4xl sm:text-5xl md:text-7xl mb-6 sm:mb-8"
          >
            Photo <span class="text-primary">Gallery</span>
          </h1>
        </div>
        <div class="reveal delay-200">
          <p
            data-i18n="galeri.desc"
            class="text-base sm:text-lg opacity-70 leading-relaxed max-w-2xl mx-auto"
          >
            A collection of operational activities, from training and operations
            to peacekeeping missions.
          </p>
        </div>
      </div>
    </section>

    <section class="camo-bg">
      <div
        class="mb-8 sm:mb-12 flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4 border-b border-primary/10 pb-4 sm:pb-6"
      >
        <span
          data-i18n="galeri.showing"
          class="text-[10px] font-bold uppercase tracking-widest opacity-40"
          >All Documentation</span
        >
        <div
          class="flex flex-wrap gap-3 sm:gap-4 text-[10px] font-bold uppercase tracking-widest text-accent"
        >
          <span
            data-i18n="galeri.filter.all"
            class="cursor-pointer border-b border-accent">All</span
          >
          <span
            data-i18n="galeri.filter.training"
            class="cursor-pointer opacity-40 hover:opacity-100 transition-opacity"
            >Training</span
          >
          <span
            data-i18n="galeri.filter.ops"
            class="cursor-pointer opacity-40 hover:opacity-100 transition-opacity"
            >Operations</span
          >
          <span
            data-i18n="galeri.filter.un"
            class="cursor-pointer opacity-40 hover:opacity-100 transition-opacity"
            >International Missions</span
          >
        </div>
      </div>

      <div class="reveal-scale">
        <Gallery />
      </div>

      <div
        class="mt-20 p-8 border border-accent/20 text-center max-w-2xl mx-auto reveal"
      >
        <h3 data-i18n="galeri.note.title" class="text-xl mb-4 text-accent">
          Note
        </h3>
        <p data-i18n="galeri.note.desc" class="text-sm opacity-60">
          All photos on this page are sourced from public documentation and used
          for educational purposes.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
