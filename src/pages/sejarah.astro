---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Timeline from "../components/Timeline.astro";
import { historyChapters, stats } from "../data/content";
---

<Layout
  title="History"
  description="The history and development of [Unit Name] from its founding to the present day."
>
  <Navbar />
  <main>
    <!-- Header -->
    <section
      class="pt-24 sm:pt-32 pb-16 sm:pb-24 bg-secondary text-primary-content relative overflow-hidden"
    >
      <div class="absolute inset-0 opacity-5">
        <!-- CUSTOMIZE: Replace background image -->
        <img
          src={historyChapters[0].image.src}
          alt=""
          class="w-full h-full object-cover grayscale"
          aria-hidden="true"
        />
      </div>
      <div class="max-w-4xl mx-auto text-center relative z-10">
        <div class="reveal">
          <span
            data-i18n="sejarah.label"
            class="text-accent text-[10px] font-bold uppercase tracking-[0.5em] mb-6 block"
            >History</span
          >
        </div>
        <div class="reveal delay-100">
          <h1
            data-i18n-html="sejarah.title"
            class="text-4xl sm:text-6xl md:text-8xl mb-6 sm:mb-8"
          >
            From [Original Name] <span class="text-accent">to [Unit Name]</span>
          </h1>
        </div>
        <div class="reveal delay-200">
          <div class="w-16 h-[2px] bg-accent mx-auto mb-8"></div>
          <p
            data-i18n="sejarah.subtitle"
            class="text-base sm:text-lg opacity-60 leading-relaxed font-body max-w-xl mx-auto"
          >
            Over six decades as a strategic reserve force.
          </p>
        </div>
      </div>
    </section>

    <!-- Chapters -->
    <section class="py-32">
      {
        historyChapters.map((ch, index) => (
          <div
            class={`grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-24 items-center ${index < historyChapters.length - 1 ? "mb-20 md:mb-32" : ""}`}
          >
            {/* Image side */}
            <div
              class={`relative ${index % 2 === 0 ? "reveal-left" : "reveal-left order-2 md:order-1"}`}
            >
              {index % 2 === 0 ? (
                <>
                  <div class="absolute -top-8 -left-8 w-32 h-32 border-2 border-primary/10 -z-10 hidden md:block" />
                  <div class="absolute -bottom-8 -right-8 w-32 h-32 bg-accent/5 -z-10 hidden md:block" />
                </>
              ) : null}
              {/* CUSTOMIZE: Replace chapter images in src/assets/ */}
              <img
                src={ch.image.src}
                alt={ch.imageAlt}
                class="grayscale-[40%] hover:grayscale-0 w-full shadow-2xl transition-all duration-700"
              />
              <div
                class={`absolute bottom-4 ${index % 2 === 0 ? "left-4" : "right-4"} bg-secondary/90 px-4 py-2`}
              >
                <span
                  data-i18n={ch.captionI18nKey}
                  class="text-[9px] font-bold tracking-[0.3em] uppercase text-accent"
                >
                  {ch.caption}
                </span>
              </div>
            </div>

            {/* Text side */}
            <div
              class={`${index % 2 === 0 ? "reveal-right" : "reveal-right order-1 md:order-2"}`}
            >
              {index % 2 !== 0 ? null : (
                <span class="text-accent text-[9px] font-bold tracking-[0.4em] uppercase mb-4 block">
                  {ch.year}
                </span>
              )}
              {index % 2 !== 0 ? (
                <span class="text-accent text-[9px] font-bold tracking-[0.4em] uppercase mb-4 block">
                  {ch.year}
                </span>
              ) : null}
              <h2
                data-i18n-html={ch.titleI18nKey}
                class="text-4xl md:text-5xl mb-8"
                set:html={ch.titleHtml}
              />
              <div class="w-12 h-[2px] bg-primary/30 mb-8" />
              <div class="space-y-6 opacity-70 text-sm leading-relaxed">
                {ch.paragraphs.map((p) =>
                  p.isHtml ? (
                    <p data-i18n-html={p.i18nKey} set:html={p.text} />
                  ) : (
                    <p data-i18n={p.i18nKey}>{p.text}</p>
                  ),
                )}
              </div>
            </div>
          </div>
        ))
      }
    </section>

    <!-- Chronology Timeline -->
    <section class="bg-base-200 py-32">
      <div class="text-center mb-20 reveal">
        <span
          data-i18n="sejarah.chrono.label"
          class="text-accent text-[9px] font-bold tracking-[0.5em] uppercase mb-4 block"
          >Chronology</span
        >
        <h3
          data-i18n-html="sejarah.chrono.title"
          class="text-4xl md:text-5xl uppercase tracking-widest"
        >
          Key <span class="text-primary">Milestones</span>
        </h3>
      </div>
      <Timeline />
    </section>

    <!-- Stats -->
    <section class="bg-secondary text-primary-content py-24">
      <div
        class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-12 text-center max-w-4xl mx-auto"
      >
        {
          stats.map((stat, i) => (
            <div class={`reveal delay-${(i + 1) * 100}`}>
              <span class="font-heading text-5xl md:text-6xl text-accent block mb-2">
                {stat.value}
              </span>
              <span
                data-i18n={stat.labelI18nKey || undefined}
                class="text-[9px] font-bold tracking-[0.3em] uppercase opacity-50"
              >
                {stat.label}
              </span>
            </div>
          ))
        }
      </div>
    </section>
  </main>
  <Footer />
</Layout>
