---
// CUSTOMIZE: Gallery images are defined in src/data/content.ts
// Replace the image files in src/assets/ with your own.
import { galleryImages } from "../data/content";
---

<div
  class="gallery-grid grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-2 sm:gap-3 auto-rows-[200px] sm:auto-rows-[180px] md:auto-rows-[220px] max-w-6xl mx-auto"
>
  {
    galleryImages.map((img) => (
      <div
        class={`gallery-item relative group overflow-hidden bg-secondary ${img.span}`}
      >
        <img
          src={img.src}
          alt={img.alt}
          class="w-full h-full object-cover grayscale-[70%] transition-all duration-700 group-hover:grayscale-0 group-hover:scale-110 opacity-80 group-hover:opacity-100"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
        <div class="absolute bottom-0 left-0 right-0 z-10 p-3 sm:p-4 opacity-0 group-hover:opacity-100 transition-all translate-y-4 group-hover:translate-y-0 duration-500">
          <span
            data-i18n={img.i18n}
            class="text-[10px] md:text-xs uppercase font-bold tracking-widest text-white"
          >
            {img.alt}
          </span>
        </div>
        <div class="absolute top-3 right-3 w-3 h-3 border-t-2 border-r-2 border-accent/0 group-hover:border-accent/80 transition-all duration-500" />
        <div class="absolute bottom-3 left-3 w-3 h-3 border-b-2 border-l-2 border-accent/0 group-hover:border-accent/80 transition-all duration-500" />
      </div>
    ))
  }
</div>

<style>
  /* Reset col/row span on mobile to prevent overflow */
  @media (max-width: 639px) {
    .gallery-item {
      grid-column: span 1 !important;
      grid-row: span 1 !important;
    }
  }
</style>
