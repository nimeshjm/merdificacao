---
import DarkModeToggle from "./DarkModeToggle.astro";
import LangToggle from "./LangToggle.astro";
// CUSTOMIZE: Replace logo in src/assets/
import logo from "../assets/Lambang_Kostrad-removebg-preview.png";
import { siteConfig } from "../data/siteConfig";
---

<header class="glass-nav">
  <div
    class="max-w-[1300px] mx-auto px-4 sm:px-6 h-16 sm:h-20 flex items-center justify-between"
  >
    <div class="flex items-center gap-4">
      <a href="/" class="flex items-center gap-3 group">
        <img
          src={logo.src}
          alt={`${siteConfig.siteName} Logo`}
          class="w-10 h-10 object-contain transition-transform group-hover:scale-110"
        />
        <div class="flex flex-col">
          <span class="font-heading text-xl leading-none tracking-tighter"
            >{siteConfig.siteName}</span
          >
          <span
            data-i18n="nav.subtitle"
            class="text-[10px] uppercase tracking-widest opacity-60 font-bold"
            >{siteConfig.siteSubtitle}</span
          >
        </div>
      </a>
    </div>

    <nav
      class="hidden md:flex items-center gap-8 text-xs font-bold uppercase tracking-widest"
    >
      {
        siteConfig.navLinks.map((link) => (
          <a
            href={link.href}
            class="hover:text-primary transition-colors"
            data-i18n={link.i18nKey}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <LangToggle />
      <DarkModeToggle />
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 hover:bg-base-200 transition-colors cursor-pointer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="3" y1="12" x2="21" y2="12"></line><line
            x1="3"
            y1="6"
            x2="21"
            y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
        >
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-base-content/10 bg-base-100/95 backdrop-blur-md"
  >
    <nav
      class="flex flex-col py-4 px-4 sm:px-6 space-y-3 text-xs font-bold uppercase tracking-widest"
    >
      {
        siteConfig.navLinks.map((link) => (
          <a
            href={link.href}
            class="hover:text-primary transition-colors py-2"
            data-i18n={link.i18nKey}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script is:inline>
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  if (menuBtn && mobileMenu) {
    // Set initial state
    mobileMenu.style.maxHeight = "0";
    mobileMenu.style.overflow = "hidden";
    mobileMenu.style.transition = "max-height 0.3s ease-in-out";
    mobileMenu.classList.remove("hidden");

    menuBtn.addEventListener("click", () => {
      if (
        mobileMenu.style.maxHeight === "0px" ||
        mobileMenu.style.maxHeight === "0"
      ) {
        mobileMenu.style.maxHeight = mobileMenu.scrollHeight + "px";
      } else {
        mobileMenu.style.maxHeight = "0";
      }
    });

    // Close menu on link click
    mobileMenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.style.maxHeight = "0";
      });
    });
  }
</script>
