---
import { timelineEvents } from "../data/content";
---

<div class="relative max-w-3xl mx-auto py-10">
  <div
    class="absolute left-6 sm:left-1/2 transform sm:-translate-x-1/2 w-[2px] h-full bg-gradient-to-b from-primary/0 via-primary/40 to-primary/0"
  >
  </div>

  {
    timelineEvents.map((event, index) => (
      <div
        class={`relative mb-20 flex flex-col sm:flex-row items-start ${index % 2 === 0 ? "sm:flex-row-reverse" : ""} reveal ${index % 2 === 0 ? "delay-100" : "delay-200"}`}
      >
        <div class="absolute left-6 sm:left-1/2 transform -translate-x-1/2 z-10 flex flex-col items-center">
          <div class="w-4 h-4 bg-primary border-4 border-base-100 rounded-full shadow-[0_0_0_4px_rgba(75,83,32,0.15)] transition-all duration-500 hover:scale-150 hover:bg-accent" />
        </div>
        <div
          class={`w-full sm:w-[45%] ml-16 sm:ml-0 ${index % 2 === 0 ? "sm:mr-auto sm:pr-12 sm:text-right" : "sm:ml-auto sm:pl-12 sm:text-left"}`}
        >
          <div
            class={`inline-block mb-3 ${index % 2 === 0 ? "sm:float-right sm:clear-right" : ""}`}
          >
            <span
              data-i18n={event.tagKey}
              class="text-[9px] font-bold tracking-[0.3em] uppercase px-3 py-1 border border-primary/20 text-primary bg-primary/5"
            >
              {event.tag}
            </span>
          </div>
          <div class="clear-both" />
          <span
            data-i18n={(event as any).yearKey || undefined}
            class="font-heading text-5xl text-accent/40 block mb-1 leading-none"
          >
            {event.year}
          </span>
          <h4
            data-i18n={event.titleKey}
            class="text-xl mb-3 tracking-tight font-heading"
          >
            {event.title}
          </h4>
          <div
            class={`w-12 h-[2px] bg-primary/30 mb-4 ${index % 2 === 0 ? "sm:ml-auto" : ""}`}
          />
          <p
            data-i18n={event.descKey}
            class="text-sm opacity-60 leading-relaxed font-body"
          >
            {event.description}
          </p>
        </div>
      </div>
    ))
  }

  <div
    class="absolute left-6 sm:left-1/2 transform -translate-x-1/2 bottom-0 reveal"
  >
    <div class="w-3 h-3 bg-accent rotate-45"></div>
  </div>
</div>
